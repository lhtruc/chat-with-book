SEMANTIC_CHUNK_SIMILARITY_THRESHOLD=0.55
SEMANTIC_CHUNK_OVERLAP_SENTENCES=1

RETRIEVAL_TOP_K=6
LOW_CONFIDENCE_THRESHOLD=0.35
MAX_TOOL_CALL_ROUNDS=3

